{% set extra_tools = [
    {
        "name": "Deep Researcher",
        "description": "Run a web-grounded research agent that plans, gathers evidence, and writes a cited report.",
        "url": "/tools/deep-researcher"
    },
    {
        "name": "Competitor Teardown",
        "description": "Turn competitor URLs and notes into positioning gaps, messaging angles, and copy ideas.",
        "url": "/tools/competitor-teardown"
    },
    {
        "name": "SEO Content Gap Finder",
        "description": "Build an SEO brief from your site, competitors, and target topics.",
        "url": "/tools/seo-content-gap"
    },
    {
        "name": "Offer Generator",
        "description": "Package a service or product into clearer tiers, bonuses, guarantees, and CTAs.",
        "url": "/tools/offer-generator"
    },
    {
        "name": "Keyword & Glossary Explorer",
        "description": "Explore related words, definitions, SEO keywords, and glossary terms for any topic.",
        "url": "/tools/keyword-explorer"
    },
    {
        "name": "Speech to Speech",
        "description": "Send audio + an optional prompt to Gemma and get a spoken Kokoro TTS reply in one request.",
        "url": "/tools/speech-to-speech"
    }
] %}
{% set ns = namespace(all_tools=tools|list) %}
{% set tool_urls = tools | map(attribute='url') | list %}
{% for tool in extra_tools %}
    {% if tool.url not in tool_urls %}
        {% set ns.all_tools = ns.all_tools + [tool] %}
    {% endif %}
{% endfor %}

{% set tool_ui = {
    "/tools/deep-researcher": {"icon": "manage_search", "label": "Research", "accent": "#c2410c", "accent_soft": "rgba(194, 65, 12, 0.14)"},
    "/tools/competitor-teardown": {"icon": "radar", "label": "Strategy", "accent": "#ea580c", "accent_soft": "rgba(234, 88, 12, 0.14)"},
    "/tools/seo-content-gap": {"icon": "travel_explore", "label": "SEO", "accent": "#f97316", "accent_soft": "rgba(249, 115, 22, 0.14)"},
    "/tools/offer-generator": {"icon": "sell", "label": "Offers", "accent": "#fb923c", "accent_soft": "rgba(251, 146, 60, 0.15)"},
    "/tools/domain-generator": {"icon": "public", "label": "Branding", "accent": "#f59e0b", "accent_soft": "rgba(245, 158, 11, 0.15)"},
    "/ai-text-editor": {"icon": "edit_note", "label": "Writing", "accent": "#d97706", "accent_soft": "rgba(217, 119, 6, 0.14)"},
    "/tools/prompt-optimizer": {"icon": "auto_fix_high", "label": "Prompting", "accent": "#ea580c", "accent_soft": "rgba(234, 88, 12, 0.14)"},
    "/tools/image-captioning-ai": {"icon": "image_search", "label": "Vision", "accent": "#fb923c", "accent_soft": "rgba(251, 146, 60, 0.14)"},
    "/tools/keyword-explorer": {"icon": "library_books", "label": "Keywords", "accent": "#f97316", "accent_soft": "rgba(249, 115, 22, 0.14)"},
    "/tools/speech-to-speech": {"icon": "record_voice_over", "label": "Audio", "accent": "#ea580c", "accent_soft": "rgba(234, 88, 12, 0.14)"}
} %}
{% set default_ui = {"icon": "bolt", "label": "AI Tool", "accent": "#c2410c", "accent_soft": "rgba(194, 65, 12, 0.14)"} %}

<style>
    .tg-tools-page {
        position: relative;
        background:
            linear-gradient(180deg, #fff7ed 0%, #fffaf5 44%, #fffdfb 100%);
    }

    .tg-tools-page::before {
        content: "";
        position: absolute;
        inset: 0 0 auto;
        height: 320px;
        background:
            radial-gradient(circle at top left, rgba(249, 115, 22, 0.2), transparent 36%),
            linear-gradient(145deg, #7c2d12 0%, #c2410c 50%, #fff7ed 50.1%, #fffdfb 100%);
        z-index: 0;
        pointer-events: none;
    }

    .tg-tools-page.demo-main {
        margin-top: 0;
    }

    .tg-tools-page .demo-container,
    .tg-tools-page .demo-content {
        position: relative;
        z-index: 1;
    }

    .tg-tools-page .demo-container {
        box-sizing: border-box;
        max-width: 1280px;
        width: calc(100% - 24px);
        padding-top: 24px;
    }

    .tg-tools-page .demo-content {
        margin-top: 24px;
        margin-bottom: 60px;
        padding: 24px;
        border-radius: 28px;
        background: rgba(255, 255, 255, 0.94);
        box-shadow: 0 28px 70px rgba(16, 32, 51, 0.16);
        backdrop-filter: blur(10px);
    }

    .tg-tools-page .demo-content h3 {
        margin-top: 0;
    }

    .tg-tools-hero {
        margin-bottom: 16px;
        color: #102033;
    }

    .tg-tools-hero h1 {
        margin: 10px 0 8px;
        font-family: 'Sora', 'Segoe UI', sans-serif;
        font-size: clamp(1.7rem, 2.6vw, 2.3rem);
        line-height: 1.05;
        letter-spacing: -0.04em;
        color: #102033;
    }

    .tg-tools-lead {
        max-width: 720px;
        margin: 0;
        font: 500 0.98rem/1.6 'Sora', 'Segoe UI', sans-serif;
        color: #4d6277;
    }

    .tg-tools-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin: 14px 0 0;
    }

    .tg-tools-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-sizing: border-box;
        min-height: 46px;
        padding: 0 18px;
        border-radius: 999px;
        border: 1px solid transparent;
        text-decoration: none;
        font: 700 0.92rem/1 'Sora', 'Segoe UI', sans-serif;
        transition: transform 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease;
    }

    .tg-tools-btn:hover {
        transform: translateY(-1px);
    }

    .tg-tools-btn--primary {
        color: #fff !important;
        -webkit-text-fill-color: #fff;
        background: linear-gradient(135deg, #ea580c, #fb923c);
        box-shadow: 0 16px 34px rgba(234, 88, 12, 0.28);
    }

    .tg-tools-btn--ghost {
        color: #0f2d55;
        border-color: rgba(15, 45, 85, 0.14);
        background: rgba(15, 45, 85, 0.04);
    }

    .tg-tools-search-wrap {
        margin: 0 0 18px;
        padding: 14px;
        border: 1px solid #f0dcc8;
        border-radius: 18px;
        background: linear-gradient(180deg, #fffaf5, #fff6ee);
    }

    .tg-tools-results,
    .tg-tools-empty p {
        color: #7c5b43;
        font-family: 'Sora', 'Segoe UI', sans-serif;
    }

    .tg-tools-search-input {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        align-items: center;
        gap: 10px;
        min-height: 50px;
        padding: 0 10px 0 14px;
        border: 1px solid #edd8c5;
        border-radius: 14px;
        background: #fff;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
    }

    .tg-tools-search-input:focus-within {
        border-color: rgba(234, 88, 12, 0.38);
        box-shadow: 0 0 0 4px rgba(234, 88, 12, 0.12);
    }

    .tg-tools-search-input .material-icons {
        color: #c2410c;
    }

    .tg-tools-search-input input {
        width: 100%;
        border: 0;
        outline: 0;
        padding: 0;
        background: transparent;
        font: 500 1rem/1.2 'Sora', 'Segoe UI', sans-serif;
        color: #102033;
    }

    .tg-tools-search-input input::placeholder {
        color: #8aa0b3;
    }

    .tg-tools-search-clear {
        border: 0;
        border-radius: 999px;
        padding: 8px 12px;
        color: #9a3412;
        background: #fde8d8;
        font: 600 0.82rem/1 'Sora', 'Segoe UI', sans-serif;
        cursor: pointer;
    }

    .tg-tools-search-clear[hidden] {
        display: none;
    }

    .tg-tools-results {
        margin: 10px 2px 0;
        font-size: 0.86rem;
    }

    .tg-tools-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
    }

    .tg-tools-card {
        display: flex;
        flex-direction: column;
        gap: 14px;
        min-height: 196px;
        padding: 20px;
        border: 1px solid #f0dcc8;
        border-radius: 24px;
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 248, 241, 0.94)),
            var(--tool-glow, transparent);
        box-shadow: 0 18px 42px rgba(16, 32, 51, 0.08);
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    }

    .tg-tools-card:hover {
        transform: translateY(-3px);
        border-color: rgba(234, 88, 12, 0.22);
        box-shadow: 0 22px 48px rgba(16, 32, 51, 0.12);
    }

    .tg-tools-card[hidden] {
        display: none;
    }

    .tg-tools-card-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .tg-tools-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 58px;
        height: 58px;
        border-radius: 18px;
        color: var(--tool-accent);
        background: var(--tool-accent-soft);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.55);
    }

    .tg-tools-icon .material-icons {
        font-size: 28px;
    }

    .tg-tools-chip {
        padding: 8px 11px;
        border-radius: 999px;
        font: 700 0.76rem/1 'IBM Plex Mono', monospace;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #9a3412;
        background: #fff1e6;
    }

    .tg-tools-card h3 {
        margin: 0;
        font: 700 1.18rem/1.22 'Sora', 'Segoe UI', sans-serif;
        letter-spacing: -0.03em;
        color: #1f1309;
    }

    .tg-tools-card p {
        margin: 0;
        color: #6f563f;
        font: 500 0.95rem/1.65 'Sora', 'Segoe UI', sans-serif;
    }

    .tg-tools-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-top: auto;
    }

    .tg-tools-card-footer a {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #9a3412;
        text-decoration: none;
        font: 700 0.9rem/1 'Sora', 'Segoe UI', sans-serif;
    }

    .tg-tools-card-footer .material-icons {
        font-size: 18px;
    }

    .tg-tools-card-note {
        color: #a56a40;
        font: 600 0.8rem/1 'IBM Plex Mono', monospace;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .tg-tools-empty {
        padding: 36px 18px 18px;
        text-align: center;
    }

    .tg-tools-empty[hidden] {
        display: none;
    }

    .tg-tools-empty .material-icons {
        font-size: 42px;
        color: #c2410c;
    }

    .tg-tools-empty h3 {
        margin: 12px 0 8px;
        font: 700 1.12rem/1.2 'Sora', 'Segoe UI', sans-serif;
        color: #102033;
    }

    .tg-tools-empty button {
        margin-top: 6px;
    }

    @media (max-width: 1180px) {
        .tg-tools-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (max-width: 1100px) {
        .tg-tools-hero {
            grid-template-columns: 1fr;
        }

        .tg-tools-page .demo-content {
            padding: 22px;
        }
    }

    @media (max-width: 820px) {
        .tg-tools-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 840px) {
        .tg-tools-page::before {
            height: 360px;
        }

        .tg-tools-page .demo-content {
            margin-top: 20px;
            border-radius: 22px;
        }

        .tg-tools-search-input {
            grid-template-columns: auto minmax(0, 1fr);
        }

        .tg-tools-search-clear {
            grid-column: 1 / -1;
            justify-self: start;
            margin: 0 0 10px 42px;
        }
    }

    @media (max-width: 640px) {
        .tg-tools-page .demo-container {
            width: calc(100% - 12px);
        }

        .tg-tools-page .demo-content {
            padding: 18px;
        }

        .tg-tools-hero h1 {
            font-size: 2rem;
        }

        .tg-tools-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .tg-tools-btn {
            width: 100%;
        }

        .tg-tools-card {
            min-height: 0;
            padding: 18px;
        }
    }
</style>

<main class="demo-main mdl-layout mdl-layout__content tg-tools-page">
    <div class="demo-container mdl-grid">
        <div class="mdl-cell mdl-cell--1-col mdl-cell--hide-tablet mdl-cell--hide-phone"></div>
        <div class="demo-content mdl-color--white mdl-shadow--4dp content mdl-color-text--grey-800 mdl-cell mdl-cell--10-col">
            <section class="tg-tools-hero">
                <div class="demo-crumbs mdl-color-text--grey-500">
                    <a href="/" title="Text Generator">Text Generator</a> > Tools
                </div>
                <h1>Find the right AI workflow.</h1>
                <p class="tg-tools-lead">
                    Prebuilt tools for domains, prompts, SEO, offers, document editing, and image understanding —
                    search and jump straight in.
                </p>
                <div class="tg-tools-actions">
                    <a class="tg-tools-btn tg-tools-btn--primary" href="/signup">Try Our Tools</a>
                    <a class="tg-tools-btn tg-tools-btn--ghost" href="/playground">Open Playground</a>
                </div>
            </section>

            <section class="tg-tools-search-wrap" aria-label="Search tools">
                <label class="tg-tools-search-input" for="tools-search">
                    <i class="material-icons" aria-hidden="true">search</i>
                    <input
                        id="tools-search"
                        type="search"
                        placeholder="Search domains, prompts, SEO, images..."
                        autocomplete="off"
                        spellcheck="false">
                    <button type="button" class="tg-tools-search-clear" id="tools-search-clear" hidden>Clear</button>
                </label>
                <p class="tg-tools-results" id="tools-results" aria-live="polite">
                    Showing <strong id="tools-visible-count">{{ ns.all_tools|length }}</strong> of <strong>{{ ns.all_tools|length }}</strong> tools
                </p>
            </section>

            <section>
                <div class="tg-tools-grid" id="tools-grid">
                    {% for tool in ns.all_tools %}
                        {% set ui = tool_ui.get(tool.url, default_ui) %}
                        <article
                            class="tg-tools-card"
                            data-tool-card
                            data-search-text="{{ (tool.name ~ ' ' ~ tool.description ~ ' ' ~ ui.label)|lower }}"
                            style="--tool-accent: {{ ui.accent }}; --tool-accent-soft: {{ ui.accent_soft }};">
                            <div class="tg-tools-card-top">
                                <span class="tg-tools-icon">
                                    <i class="material-icons" aria-hidden="true">{{ ui.icon }}</i>
                                </span>
                                <span class="tg-tools-chip">{{ ui.label }}</span>
                            </div>
                            <h3>{{ tool.name }}</h3>
                            <p>{{ tool.description }}</p>
                            <div class="tg-tools-card-footer">
                                <a href="{{ tool.url }}">
                                    Open tool
                                    <i class="material-icons" aria-hidden="true">arrow_forward</i>
                                </a>
                                <span class="tg-tools-card-note">{{ ui.label }}</span>
                            </div>
                        </article>
                    {% endfor %}
                </div>

                <div class="tg-tools-empty" id="tools-empty" hidden>
                    <i class="material-icons" aria-hidden="true">search_off</i>
                    <h3>No tools match that search.</h3>
                    <p>Try a broader term like <strong>SEO</strong>, <strong>prompt</strong>, <strong>image</strong>, or <strong>domain</strong>.</p>
                    <button type="button" class="tg-tools-search-clear" id="tools-empty-reset">Reset search</button>
                </div>
            </section>
        </div>
    </div>
{% import "templates/macros.jinja2" as macros with context %}

{{ macros.svgstyled() }}
</main>

<script>
    (function () {
        var searchInput = document.getElementById('tools-search');
        var clearButton = document.getElementById('tools-search-clear');
        var emptyReset = document.getElementById('tools-empty-reset');
        var results = document.getElementById('tools-visible-count');
        var emptyState = document.getElementById('tools-empty');
        var cards = Array.prototype.slice.call(document.querySelectorAll('[data-tool-card]'));

        if (!searchInput || !results || !emptyState || !cards.length) {
            return;
        }

        function applyFilter() {
            var query = searchInput.value.trim().toLowerCase();
            var visible = 0;

            cards.forEach(function (card) {
                var match = !query || card.dataset.searchText.indexOf(query) !== -1;
                card.hidden = !match;
                if (match) {
                    visible += 1;
                }
            });

            results.textContent = String(visible);
            emptyState.hidden = visible !== 0;

            if (clearButton) {
                clearButton.hidden = query.length === 0;
            }
        }

        function resetSearch() {
            searchInput.value = '';
            applyFilter();
            searchInput.focus();
        }

        searchInput.addEventListener('input', applyFilter);

        if (clearButton) {
            clearButton.addEventListener('click', resetSearch);
        }

        if (emptyReset) {
            emptyReset.addEventListener('click', resetSearch);
        }

        applyFilter();
    })();
</script>
