<script>
(function () {
    const examples = {
        'image-analysis': {
            prompt: 'Which fairy looks the most playful and why?\n1: https://static.text-generator.io/static/img/fairy1.jpeg\n2: https://static.text-generator.io/static/img/fairy2.jpeg\nAnswer:',
            output: 'The first fairy reads as most playful because the brighter palette and pose feel energetic and friendly.'
        },
        review: {
            prompt: 'Write a restaurant review from these notes:\nName: The Blue Wharf\nLobster excellent, noisy room, polite service.\nReview:',
            output: 'The lobster was excellent and worth returning for. The room gets noisy, but service stayed attentive and polite.'
        },
        code: {
            prompt: '# Build a simple PyTorch classifier\nimport torch\nimport torch.nn as nn\nimport torch.optim as optim\n',
            output: 'class Net(nn.Module):\n    def __init__(self):\n        super().__init__()\n        self.layers = nn.Sequential(nn.Linear(32, 64), nn.ReLU(), nn.Linear(64, 2))\n'
        },
        chat: {
            prompt: 'User: How do I center a div with flexbox?\nAI:',
            output: 'Use display: flex; justify-content: center; align-items: center; on the parent container.'
        }
    };

    const panel = document.getElementById('demo-panel');
    const tabs = document.querySelectorAll('.tg-demo-tab');

    function renderExample(key) {
        const example = examples[key];
        if (!example || !panel) return;

        panel.innerHTML = `${example.prompt}<div class="tg-demo-output">${example.output}</div>`;

        tabs.forEach((tab) => {
            tab.classList.toggle('is-active', tab.dataset.example === key);
        });
    }

    tabs.forEach((tab) => {
        tab.addEventListener('click', () => renderExample(tab.dataset.example));
    });

    renderExample('image-analysis');
})();
</script>
