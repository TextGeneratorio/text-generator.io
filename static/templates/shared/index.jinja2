        <a href="https://github.com/TextGeneratorio/text-generator.io" target="_blank" rel="noopener noreferrer" class="tg-btn tg-btn--light tg-btn--xl">Explore the source <i class="material-icons">north_east</i></a>
    </div>
</section>

