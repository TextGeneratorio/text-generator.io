        <a class="mdl-navigation__link header-subscribe" href="#" onclick="showCheckoutDialog('monthly'); return false;" style="display: none;"><i class="material-icons">workspace_premium</i>Upgrade</a>
        <a class="mdl-navigation__link header-account" href="/account" style="display: none;"><i class="material-icons">person</i>Account</a>
