        <a class="mdl-navigation__link" href="/text-to-speech"><i class="material-icons">record_voice_over</i>Text To Speech</a>
        <a class="mdl-navigation__link" href="/speech-to-text"><i class="material-icons">graphic_eq</i>Speech To Text</a>
        <a class="mdl-navigation__link" href="/bulk-text-generator"><i class="material-icons">view_list</i>Bulk Generator</a>
