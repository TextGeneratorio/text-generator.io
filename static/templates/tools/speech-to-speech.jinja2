<style>
    .s2s-wrap {
        max-width: 760px;
        margin: 24px auto 80px;
        padding: 28px;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 18px 48px rgba(16, 32, 51, 0.1);
        font-family: 'Sora', 'Segoe UI', sans-serif;
        color: #102033;
    }
    .s2s-wrap h1 {
        margin: 0 0 6px;
        font-size: 1.9rem;
        letter-spacing: -0.02em;
    }
    .s2s-wrap p.lead {
        margin: 0 0 22px;
        color: #4d6277;
    }
    .s2s-field { margin-bottom: 16px; }
    .s2s-field label {
        display: block;
        font-weight: 600;
        font-size: 0.88rem;
        margin-bottom: 6px;
        color: #1f2937;
    }
    .s2s-field input[type=text],
    .s2s-field select,
    .s2s-field textarea {
        width: 100%;
        padding: 11px 13px;
        border: 1px solid #d6dde5;
        border-radius: 10px;
        font-size: 0.96rem;
        font-family: inherit;
        box-sizing: border-box;
        background: #fff;
    }
    .s2s-field textarea { min-height: 72px; resize: vertical; }
    .s2s-row { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
    .s2s-file-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        background: #fff4eb;
        border: 1px solid #f4c3a0;
        color: #9a3412;
        border-radius: 10px;
        cursor: pointer;
        font-weight: 600;
    }
    .s2s-file-btn:hover { background: #ffe9d6; }
    #s2sAudioFile { display: none; }
    .s2s-file-name { font-size: 0.88rem; color: #4d6277; }
    .s2s-record-btn, .s2s-stop-btn {
        padding: 10px 16px;
        border-radius: 10px;
        border: 1px solid #d6dde5;
        background: #fff;
        cursor: pointer;
        font-weight: 600;
    }
    .s2s-record-btn.recording { background: #fee2e2; border-color: #f87171; color: #b91c1c; }
    .s2s-stop-btn[disabled] { opacity: 0.5; cursor: not-allowed; }
    .s2s-submit {
        margin-top: 6px;
        padding: 13px 28px;
        border: 0;
        border-radius: 12px;
        background: linear-gradient(135deg, #ea580c, #fb923c);
        color: #fff;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        box-shadow: 0 14px 30px rgba(234, 88, 12, 0.26);
    }
    .s2s-submit[disabled] { opacity: 0.6; cursor: not-allowed; }
    .s2s-result {
        margin-top: 24px;
        padding: 18px;
        border: 1px solid #e7edf3;
        border-radius: 14px;
        background: #f8fafc;
    }
    .s2s-result[hidden] { display: none; }
    .s2s-result h3 { margin: 0 0 10px; font-size: 1rem; }
    .s2s-result audio { width: 100%; margin-top: 10px; }
    .s2s-result pre {
        white-space: pre-wrap;
        margin: 0;
        font-family: inherit;
        color: #102033;
    }
    .s2s-error { color: #b91c1c; margin-top: 10px; }
    .s2s-status { font-size: 0.88rem; color: #6b7280; margin-top: 8px; min-height: 18px; }
</style>

<div class="demo-ribbon"></div>
<main class="demo-main mdl-layout mdl-layout__content">
    <div class="s2s-wrap">
        <h1>Speech to Speech</h1>
        <p class="lead">
            Record or upload audio, optionally add a text prompt, and get back a spoken reply.
            Powered by <b>Gemma 4</b> multimodal audio understanding and <b>Kokoro TTS</b>, all in one request to
            <code>/api/v1/multimodal-generate</code>.
        </p>

        <div class="s2s-field">
            <label>Audio input</label>
            <div class="s2s-row">
                <input id="s2sAudioFile" type="file" accept="audio/*">
                <label for="s2sAudioFile" class="s2s-file-btn">Choose file</label>
                <button type="button" id="s2sRecordBtn" class="s2s-record-btn">🎤 Record</button>
                <button type="button" id="s2sStopBtn" class="s2s-stop-btn" disabled>⏹ Stop</button>
                <span class="s2s-file-name" id="s2sFileName">No audio selected</span>
            </div>
        </div>

        <div class="s2s-field">
            <label for="s2sText">Text prompt (optional)</label>
            <textarea id="s2sText" placeholder="e.g. Answer this question concisely, or translate it to French."></textarea>
        </div>

        <div class="s2s-row">
            <div class="s2s-field" style="flex:1; min-width: 180px;">
                <label for="s2sVoice">Voice</label>
                <select id="s2sVoice">
                    <optgroup label="Kokoro">
                        <option value="af_heart">af_heart (American female)</option>
                        <option value="af_bella">af_bella</option>
                        <option value="af_nova">af_nova</option>
                        <option value="am_adam">am_adam (American male)</option>
                        <option value="am_michael">am_michael</option>
                        <option value="bf_emma">bf_emma (British female)</option>
                        <option value="bm_george">bm_george (British male)</option>
                    </optgroup>
                    <optgroup label="Supertonic multilingual">
                        <option value="M1">M1</option>
                        <option value="M2">M2</option>
                        <option value="M3">M3</option>
                        <option value="M4">M4</option>
                        <option value="M5">M5</option>
                        <option value="F1">F1</option>
                        <option value="F2">F2</option>
                        <option value="F3">F3</option>
                        <option value="F4">F4</option>
                        <option value="F5">F5</option>
                    </optgroup>
                </select>
            </div>
            <div class="s2s-field" style="flex:1; min-width: 180px;">
                <label for="s2sLanguage">Language</label>
                <select id="s2sLanguage">
                    <option value="en" selected>English</option>
                    <option value="ko">Korean</option>
                    <option value="ja">Japanese</option>
                    <option value="ar">Arabic</option>
                    <option value="bg">Bulgarian</option>
                    <option value="cs">Czech</option>
                    <option value="da">Danish</option>
                    <option value="de">German</option>
                    <option value="el">Greek</option>
                    <option value="es">Spanish</option>
                    <option value="et">Estonian</option>
                    <option value="fi">Finnish</option>
                    <option value="fr">French</option>
                    <option value="hi">Hindi</option>
                    <option value="hr">Croatian</option>
                    <option value="hu">Hungarian</option>
                    <option value="id">Indonesian</option>
                    <option value="it">Italian</option>
                    <option value="lt">Lithuanian</option>
                    <option value="lv">Latvian</option>
                    <option value="nl">Dutch</option>
                    <option value="pl">Polish</option>
                    <option value="pt">Portuguese</option>
                    <option value="ro">Romanian</option>
                    <option value="ru">Russian</option>
                    <option value="sk">Slovak</option>
                    <option value="sl">Slovenian</option>
                    <option value="sv">Swedish</option>
                    <option value="tr">Turkish</option>
                    <option value="uk">Ukrainian</option>
                    <option value="vi">Vietnamese</option>
                </select>
            </div>
            <div class="s2s-field" style="width: 140px;">
                <label for="s2sSpeed">Speed</label>
                <input id="s2sSpeed" type="text" value="1.0">
            </div>
            <div class="s2s-field" style="width: 120px;">
                <label for="s2sSteps">Steps</label>
                <input id="s2sSteps" type="text" value="4">
            </div>
            <div class="s2s-field" style="width: 140px;">
                <label for="s2sMaxLen">Max tokens</label>
                <input id="s2sMaxLen" type="text" value="500">
            </div>
        </div>

        <button id="s2sSubmit" class="s2s-submit">Generate reply</button>
        <div class="s2s-status" id="s2sStatus"></div>
        <div class="s2s-error" id="s2sError"></div>

        <div class="s2s-result" id="s2sResult" hidden>
            <h3>Generated text</h3>
            <pre id="s2sTextOut"></pre>
            <h3 style="margin-top:14px;">Spoken reply</h3>
            <audio id="s2sAudioOut" controls></audio>
        </div>
    </div>
</main>

<script>
(function () {
    const fileInput = document.getElementById('s2sAudioFile');
    const fileName = document.getElementById('s2sFileName');
    const recordBtn = document.getElementById('s2sRecordBtn');
    const stopBtn = document.getElementById('s2sStopBtn');
    const submitBtn = document.getElementById('s2sSubmit');
    const statusEl = document.getElementById('s2sStatus');
    const errorEl = document.getElementById('s2sError');
    const resultEl = document.getElementById('s2sResult');
    const textOut = document.getElementById('s2sTextOut');
    const audioOut = document.getElementById('s2sAudioOut');
    const voiceEl = document.getElementById('s2sVoice');
    const languageEl = document.getElementById('s2sLanguage');
    const stepsEl = document.getElementById('s2sSteps');
    const supertonicVoices = new Set(['M1', 'M2', 'M3', 'M4', 'M5', 'F1', 'F2', 'F3', 'F4', 'F5']);

    function updateSupertonicControls() {
        const enabled = supertonicVoices.has(voiceEl.value);
        languageEl.disabled = !enabled;
        stepsEl.disabled = !enabled;
    }

    let secret = null;
    fetch('/api/current-user').then(r => r.ok ? r.json() : null).then(u => { if (u) secret = u.secret; }).catch(() => {});

    let recordedBlob = null;
    let mediaRecorder = null;
    let chunks = [];

    fileInput.addEventListener('change', () => {
        const f = fileInput.files[0];
        if (f) {
            recordedBlob = null;
            fileName.textContent = f.name;
        }
    });

    voiceEl.addEventListener('change', updateSupertonicControls);
    updateSupertonicControls();

    recordBtn.addEventListener('click', async () => {
        try {
            const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
            mediaRecorder = new MediaRecorder(stream);
            chunks = [];
            mediaRecorder.addEventListener('dataavailable', e => chunks.push(e.data));
            mediaRecorder.addEventListener('stop', () => {
                recordedBlob = new Blob(chunks, { type: 'audio/webm' });
                fileInput.value = '';
                fileName.textContent = 'Recorded audio (' + Math.round(recordedBlob.size / 1024) + ' KB)';
                stream.getTracks().forEach(t => t.stop());
                recordBtn.classList.remove('recording');
                recordBtn.textContent = '🎤 Record';
                recordBtn.disabled = false;
                stopBtn.disabled = true;
            });
            mediaRecorder.start();
            recordBtn.classList.add('recording');
            recordBtn.textContent = '● Recording…';
            stopBtn.disabled = false;
        } catch (err) {
            errorEl.textContent = 'Microphone access denied: ' + err.message;
        }
    });

    stopBtn.addEventListener('click', () => {
        if (mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
    });

    submitBtn.addEventListener('click', async () => {
        errorEl.textContent = '';
        resultEl.hidden = true;

        const file = fileInput.files[0];
        if (!file && !recordedBlob) {
            errorEl.textContent = 'Please upload or record some audio first.';
            return;
        }

        const fd = new FormData();
        if (file) {
            fd.append('audio_file', file);
        } else {
            fd.append('audio_file', recordedBlob, 'recording.webm');
        }
        fd.append('text', document.getElementById('s2sText').value || '');
        fd.append('voice', voiceEl.value);
        fd.append('language', languageEl.value);
        fd.append('speed', document.getElementById('s2sSpeed').value || '1.0');
        fd.append('steps', stepsEl.value || '4');
        fd.append('max_length', document.getElementById('s2sMaxLen').value || '500');

        submitBtn.disabled = true;
        submitBtn.textContent = 'Generating…';
        statusEl.textContent = 'Uploading and running Gemma + Kokoro…';
        const t0 = performance.now();

        try {
            const base = (window.fixtures && window.fixtures.inference_server_url) || 'https://api.text-generator.io';
            const resp = await fetch(base + '/api/v1/multimodal-generate', {
                method: 'POST',
                headers: secret ? { secret } : {},
                body: fd,
            });
            if (!resp.ok) {
                const t = await resp.text();
                throw new Error('HTTP ' + resp.status + ': ' + t);
            }
            const data = await resp.json();
            const ms = (performance.now() - t0).toFixed(0);
            statusEl.textContent = 'Done in ' + ms + 'ms';

            textOut.textContent = data.generated_text || '(no text)';
            if (data.audio_base64) {
                const bin = atob(data.audio_base64);
                const bytes = new Uint8Array(bin.length);
                for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
                const blob = new Blob([bytes], { type: 'audio/wav' });
                audioOut.src = URL.createObjectURL(blob);
                audioOut.play().catch(() => {});
            }
            resultEl.hidden = false;
        } catch (err) {
            errorEl.textContent = 'Error: ' + err.message;
            statusEl.textContent = '';
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Generate reply';
        }
    });
})();
</script>
